# Copy to .env.local and fill in. Convex CLI loads .env.local when you run `convex dev`.

CONVEX_DEPLOYMENT=
CONVEX_URL=
CONVEX_SITE_URL=

# Required by convex/lib/siteEnv.ts — URL of the Next.js app (Better Auth). Local dev example:
SITE_URL=http://localhost:3000

# --- Email (Resend) — set in Convex dashboard for prod, or below for `convex dev` ---
# RESEND_API_KEY=re_...
# NOTIFICATIONS_FROM_EMAIL="LoMo <notifications@yourdomain.com>"

# Masked relay: subdomain receiving inbound mail (configure MX in DNS per Resend inbound docs).
# EMAIL_RELAY_DOMAIN=reply.yourdomain.com

# Webhook signing secret from Resend → Webhooks → your endpoint (starts with whsec_).
# Point the webhook URL at: https://<deployment>.convex.site/webhooks/resend-inbound
# Events: email.received
# RESEND_WEBHOOK_SECRET=whsec_...
